//Comments like this technically violate the JSON standard, but the game will filter them out automatically when loading the file
//This is useful in case you need to add notes or instructions to your translator for specific lines.
//Note: This only works with double slash comments, not slash star comment star slash.
{
    "langs": [
        { //The first language listed is the game's native language (In this case, English)
            "langNameGameNative": "English", //The name of the language, in your game's native language
            "langNameLocal": "English",  //The name of the language, in that language
            "stringsFile": "stringsEN.json", //The name of the JSON file containing strings for the given language
            "font": "fnMain" //The name of the font asset in Game Maker
        },
        {
            "langNameGameNative": "French",
            "langNameLocal": "Français",
            "stringsFile": "stringsFR.json",
            "font": "fnMain"
        }
    ]
}